# Server configuration
PORT = 5000

# MongoDB Connection String
Mongo_URI = 'mongodb://127.0.0.1:27017/backend_project'

# JWT Secrets (Generate strong random secrets for production)
JWT_ACCESS_TOKEN = 'your_jwt_access_secret'
JWT_REFRESH_TOKEN = 'your_jwt_refresh_secret'

# Redis Configuration
REDIS_URL = 'redis://127.0.0.1:6379'

# SMTP Configuration (For Email Sending)
SMTP_HOST = 'smtp.gmail.com'
SMTP_PORT = 587
SMTP_USER = 'your_email@gmail.com'
SMTP_PASS = 'your_gmail_app_password'
SMTP_FROM = '"Feedback Portal" <your_email@gmail.com>'
